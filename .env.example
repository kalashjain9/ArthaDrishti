# ──────────────────────────────────────────────────────────────────────────────
# ArthaDrishti AI — Environment Configuration
# Copy this file to .env and fill in your API keys
# ──────────────────────────────────────────────────────────────────────────────

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-minimum-32-chars

# JWT token expiry in minutes (default: 60*24 = 1 day)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── LLM Configuration ─────────────────────────────────────────────────────────
# Provider: "openai" or "groq" (default: groq — free tier available)
LLM_PROVIDER=groq

# OpenAI API Key (used if LLM_PROVIDER=openai)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq API Key (used if LLM_PROVIDER=groq — free, fast)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# ── News API Keys (optional — app works without them using RSS fallback) ──────
# NewsAPI: https://newsapi.org/ (free tier: 100 req/day)
NEWS_API_KEY=

# GNews: https://gnews.io/ (free tier: 100 req/day)
GNEWS_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite+aiosqlite:///./arthadrishti.db

# PostgreSQL (for production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/arthadrishti

# ── Redis / Celery ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── Document Upload ───────────────────────────────────────────────────────────
UPLOAD_DIR=./uploaded_docs
MAX_FILE_SIZE_MB=50

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
